{
  "name": "@baloise/ds-css",
  "version": "20.0.0-next.3",
  "description": "UnoCSS utility preset and pre-built CSS bundle for the Helvetia Design System.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baloise/design-system.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://baloise-design-system.vercel.app",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/preset/index.js",
      "require": "./dist/preset/index.cjs"
    },
    "./css": "./dist/css/design-system.css",
    "./css/all": "./dist/css/all.css",
    "./css/all.local": "./dist/css/all.local.css",
    "./css/base": "./dist/css/base.css",
    "./css/components": "./dist/css/components.css",
    "./css/utilities": "./dist/css/utilities.css",
    "./scss/all": "./dist/scss/all.scss",
    "./scss/base": "./dist/scss/base.scss",
    "./scss/mixins": "./dist/scss/mixins.scss",
    "./scss/utilities": "./dist/scss/utilities.scss"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "node --disable-warning=DEP0205 --import tsx/esm src/build.ts"
  },
  "dependencies": {
    "@baloise/ds-tokens": "20.0.0-next.3",
    "@baloise/ds-assets": "20.0.0-next.3"
  },
  "devDependencies": {
    "autoprefixer": "10.5.0",
    "postcss": "8.5.14",
    "sass": "1.99.0",
    "tsx": "^4.19.1",
    "unocss": "^66.0.0"
  }
}
