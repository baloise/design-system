{
  "name": "css",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/css/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "node --import tsx/esm src/build.ts",
        "cwd": "{projectRoot}"
      }
    }
  },
  "tags": ["scope:release", "type:package"]
}
