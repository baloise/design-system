{
  "color": {
    "$type": "color",
    "text": {
      "white": {
        "$value": "{color.white}",
        "comment": "Main font color for all headings and paragraphs on a dark background."
      },
      "black": { "$value": "{color.black}" },

      "primary": {
        "$value": "{color.primary.5}",
        "comment": "Main font color for all headings and paragraphs."
      },
      "primary-hover": { "$value": "{color.light-blue.5}" },
      "primary-active": { "$value": "{color.primary.6}" },

      "inverted-primary": { "$value": "{color.text.white}" },
      "inverted-primary-hover": { "$value": "{color.light-blue.2}" },
      "inverted-primary-active": { "$value": "{color.info.3}" },

      "primary-light": {
        "$value": "{color.primary.3}",
        "comment": "Secondary font color for help messages."
      },
      "hint": { "$value": "{color.text.primary-light}" },

      "grey-light": {
        "$value": "{color.grey.4}",
        "comment": "Font color for disabled texts"
      },
      "grey": {
        "$value": "{color.grey.5}",
        "comment": "Font color for placeholders"
      },
      "grey-dark": {
        "$value": "{color.grey.6}",
        "comment": "Font color for disabled elements"
      },

      "disabled": { "$value": "{color.text.grey-dark}" },
      "inverted-disabled": { "$value": "{color.primary.3}" },

      "info": { "$value": "{color.info.4}" },
      "warning": { "$value": "{color.warning.5}" },
      "success": { "$value": "{color.success.4}" },
      "danger": { "$value": "{color.danger.4}" },

      "danger-hover": { "$value": "{color.danger.5}" },
      "danger-active": { "$value": "{color.danger.6}" }
    }
  }
}
