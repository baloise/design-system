# Figma Token Upload Configuration
# Copy this file to .env and fill in your values

# Your Figma Personal Access Token
# Get it from: Figma > Settings > Account > Personal access tokens
# Required scopes: File content (read/write)
FIGMA_ACCESS_TOKEN=

# Your Figma File ID
# Get it from the URL when viewing your file: figma.com/file/[FILE_ID]/...
# You can paste the full URL or just the ID
FIGMA_FILE_ID=
