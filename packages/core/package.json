{
  "name": "@baloise/ds-core",
  "version": "20.0.0-next.4",
  "description": "The Helvetia Design System is an open source project for styling awesome web applications that follow the Helvetia corporate styling guidelines.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baloise/design-system.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://design.baloise.dev",
  "security": "https://github.com/baloise/design-system/security/advisories/new",
  "license": "Apache-2.0",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "es2015": "dist/esm/index.js",
  "es2017": "dist/esm/index.js",
  "jsnext:main": "dist/esm/index.js",
  "collection:main": "dist/collection/index.js",
  "collection": "dist/collection/collection-manifest.json",
  "types": "dist/types/interfaces.d.ts",
  "files": [
    "components/",
    "dist/",
    "docs/",
    "loader/"
  ],
  "scripts": {
    "build": "node ../../scripts/build-core.mjs",
    "start": "node -e \"require('kill-port')(4000).catch(()=>{})\" && cross-env DS_DEVELOPMENT=true stencil build --dev --serve --watch --port=4000",
    "start-two": "node -e \"require('kill-port')(4001).catch(()=>{})\" && cross-env DS_DEVELOPMENT=true stencil build --dev --serve --watch --port=4001",
    "test": "vitest --run",
    "test:ui": "vitest --ui",
    "lint": "eslint .",
    "play": "node -e \"require('kill-port')(4000).catch(()=>{})\" && pnpm exec playwright test --ui",
    "play:file": "cross-env CI=1 pnpm exec playwright test",
    "play:a11y": "cross-env CI=1 pnpm exec playwright test --project='♿️ A11Y'",
    "play:components": "cross-env CI=1 pnpm exec playwright test --project='⚙️ Component'",
    "play:visual": "cross-env CI=1 pnpm exec playwright test --project='🖼️ Visual / 💻 Desktop Chrome' --project='🖼️ Visual / 📱 Mobile Chrome'",
    "play:update": "cross-env CI=1 pnpm exec playwright test --project='🖼️ Visual / 💻 Desktop Chrome' --project='🖼️ Visual / 📱 Mobile Chrome' --update-snapshots",
    "play:ci": "cross-env CI=1 pnpm exec playwright test"
  },
  "dependencies": {
    "@baloise/ds-assets": "20.0.0-next.4",
    "@baloise/ds-css": "20.0.0-next.4",
    "@baloise/ds-tokens": "20.0.0-next.4",
    "@floating-ui/dom": "^1.7.6",
    "@popperjs/core": "^2.11.4",
    "@stencil/core": "^4.43.5",
    "big.js": "^7.0.1",
    "contactjs": "^2.1.7",
    "dompurify": "3.4.11",
    "filesize.js": "^2.0.0",
    "focus-trap": "^8.2.2",
    "lodash": "^4.18.1",
    "lottie-colorify": "0.8.0",
    "lottie-web": "5.8.1",
    "luxon": "^3.7.2",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@baloise/ds-playwright": "20.0.0-next.4",
    "@types/luxon": "3.7.2",
    "compression": "1.8.1",
    "eslint": "10.5.0",
    "express": "5.2.1",
    "libs-eslint-plugin": "0.0.0",
    "libs-output-target-angular": "0.0.0",
    "libs-output-target-web": "0.0.0",
    "serve-index": "1.9.2",
    "vitest": "4.1.9"
  },
  "sideEffects": false
}
