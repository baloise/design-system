{
  "tag": {
    "font": {
      "family": {
        "$type": "font-family",
        "$value": "{font.family.text}"
      },
      "weight": {
        "$type": "font-weight",
        "small": { "$value": "{font.weight.regular}" },
        "normal": { "$value": "{font.weight.bold}" },
        "medium": { "$value": "{font.weight.bold}" },
        "large": { "$value": "{font.weight.bold}" }
      }
    },
    "line-height": {
      "$type": "number",
      "$value": "{text.line-height.text}"
    },
    "text": {
      "$type": "dimension",
      "size": {
        "small": { "$value": "{text.size.small.mobile}" },
        "normal": { "$value": "{text.size.normal.mobile}" },
        "medium": { "$value": "{text.size.normal.mobile}" },
        "large": { "$value": "{text.size.normal.mobile}" }
      }
    },
    "radius": {
      "$type": "dimension",
      "base": {
        "$value": "4"
      },
      "pill": {
        "$value": "37.5%"
      }
    },
    "color": {
      "$type": "color",
      "text": {
        "base": { "$value": "{color.text.primary}" },
        "primary": { "$value": "{color.text.white}" },
        "grey": { "$value": "{color.text.white}" },

        "info": { "$value": "{color.text.white}" },
        "success": { "$value": "{color.text.white}" },
        "warning": { "$value": "{color.text.primary}" },
        "danger": { "$value": "{color.text.white}" },

        "purple": { "$value": "{color.text.primary}" },
        "red": { "$value": "{color.text.primary}" },
        "yellow": { "$value": "{color.text.primary}" },
        "green": { "$value": "{color.text.primary}" },

        "purple-light": { "$value": "{color.text.primary}" },
        "red-light": { "$value": "{color.text.primary}" },
        "yellow-light": { "$value": "{color.text.primary}" },
        "green-light": { "$value": "{color.text.primary}" },

        "purple-dark": { "$value": "{color.text.white}" },
        "red-dark": { "$value": "{color.text.white}" },
        "yellow-dark": { "$value": "{color.text.white}" },
        "green-dark": { "$value": "{color.text.white}" }
      },
      "background": {
        "base": { "$value": "{color.background.grey}" },
        "primary": { "$value": "{color.background.primary}" },
        "grey": { "$value": "{color.grey.4}" },

        "info": { "$value": "{color.info.4}" },
        "success": { "$value": "{color.success.4}" },
        "warning": { "$value": "{color.warning.4}" },
        "danger": { "$value": "{color.danger.4}" },

        "purple-dark": { "$value": "{color.purple.6}" },
        "red-dark": { "$value": "{color.red.6}" },
        "yellow-dark": { "$value": "{color.yellow.6}" },
        "green-dark": { "$value": "{color.green.6}" },

        "purple": { "$value": "{color.background.purple}" },
        "red": { "$value": "{color.background.red}" },
        "yellow": { "$value": "{color.background.yellow}" },
        "green": { "$value": "{color.background.green}" },

        "purple-light": { "$value": "{color.background.purple-light}" },
        "red-light": { "$value": "{color.background.red-light}" },
        "yellow-light": { "$value": "{color.background.yellow-light}" },
        "green-light": { "$value": "{color.background.green-light}" }
      }
    }
  }
}
