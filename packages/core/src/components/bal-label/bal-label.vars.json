{
  "label": {
    "font": {
      "family": {
        "$type": "font-family",
        "$value": "{font.family.text}"
      },
      "weight": {
        "$type": "font-weight",
        "$value": "{font.weight.bold}"
      }
    },
    "line-height": {
      "$type": "number",
      "$value": "{text.line-height.text}"
    },
    "color": {
      "$type": "color",
      "base": { "$value": "{color.text.primary}" },
      "success": { "$value": "{color.text.success}" },
      "danger": { "$value": "{color.text.danger}" },
      "warning": { "$value": "{color.text.warning}" },
      "hover": { "$value": "{color.text.primary-hover}" },
      "active": { "$value": "{color.text.primary-active}" },
      "danger-hover": { "$value": "{color.text.danger-hover}" },
      "danger-active": { "$value": "{color.text.danger-active}" },
      "disabled": { "$value": "{color.text.disabled}" }
    },
    "size": {
      "$type": "dimension",
      "xxx-large": {
        "mobile": {
          "$value": "{text.size.xxx-large.mobile}"
        },
        "tablet": {
          "$value": "{text.size.xxx-large.tablet}"
        },
        "desktop": {
          "$value": "{text.size.xxx-large.desktop}"
        }
      },
      "xx-large": {
        "mobile": {
          "$value": "{text.size.xx-large.mobile}"
        },
        "tablet": {
          "$value": "{text.size.xx-large.tablet}"
        },
        "desktop": {
          "$value": "{text.size.xx-large.desktop}"
        }
      },
      "x-large": {
        "mobile": {
          "$value": "{text.size.x-large.mobile}"
        },
        "tablet": {
          "$value": "{text.size.x-large.tablet}"
        },
        "desktop": {
          "$value": "{text.size.x-large.desktop}"
        }
      },
      "large": {
        "mobile": {
          "$value": "{text.size.large.mobile}"
        },
        "tablet": {
          "$value": "{text.size.large.tablet}"
        },
        "desktop": {
          "$value": "{text.size.large.desktop}"
        }
      },
      "medium": {
        "mobile": {
          "$value": "{text.size.medium.mobile}"
        },
        "tablet": {
          "$value": "{text.size.medium.tablet}"
        },
        "desktop": {
          "$value": "{text.size.medium.desktop}"
        }
      },
      "normal": {
        "mobile": {
          "$value": "{text.size.normal.mobile}"
        },
        "tablet": {
          "$value": "{text.size.normal.tablet}"
        },
        "desktop": {
          "$value": "{text.size.normal.desktop}"
        }
      },
      "small": {
        "mobile": {
          "$value": "{text.size.small.mobile}"
        },
        "tablet": {
          "$value": "{text.size.small.tablet}"
        },
        "desktop": {
          "$value": "{text.size.small.desktop}"
        }
      }
    }
  }
}
