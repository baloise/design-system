{
  "badge": {
    "font": {
      "family": {
        "$type": "font-family",
        "$value": "{font.family.title}"
      },
      "weight": {
        "$type": "font-weight",
        "$value": "{font.weight.bold}"
      }
    },
    "space": {
      "$type": "dimension",
      "base": {
        "$value": "8"
      }
    },
    "size": {
      "$type": "dimension",
      "small": { "$value": "12" },
      "normal": { "$value": "24" },
      "large": { "$value": "32" }
    },
    "color": {
      "$type": "color",
      "text": {
        "base": { "$value": "{color.text.primary}" },
        "red": { "$value": "{color.text.primary}" },
        "green": { "$value": "{color.text.primary}" },
        "yellow": { "$value": "{color.text.primary}" },
        "purple": { "$value": "{color.text.primary}" },
        "grey": { "$value": "{color.text.grey-dark}" },
        "success": { "$value": "{color.text.primary}" },
        "warning": { "$value": "{color.text.primary}" },
        "danger": { "$value": "{color.text.primary}" }
      },
      "background": {
        "base": { "$value": "{color.background.red}" },
        "red": { "$value": "{color.background.red}" },
        "green": { "$value": "{color.background.green}" },
        "yellow": { "$value": "{color.background.yellow}" },
        "purple": { "$value": "{color.background.purple}" },
        "grey": { "$value": "{color.background.grey}" },
        "success": { "$value": "{color.background.green}" },
        "warning": { "$value": "{color.background.yellow}" },
        "danger": { "$value": "{color.background.red}" }
      }
    }
  }
}
