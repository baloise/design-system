{
  "link": {
    "font": {
      "family": {
        "$type": "font-family",
        "$value": "inherit"
      },
      "weight": {
        "$type": "font-weight",
        "$value": "{font.weight.bold}"
      }
    },
    "line-height": {
      "$type": "number",
      "$value": "{text.line-height.text}"
    },
    "text": {
      "decoration": {
        "$value": "underline"
      },
      "underline-offset": {
        "$value": "0.25rem"
      },
      "decoration-thickness": {
        "$value": "{border.width.base}"
      }
    },
    "color": {
      "$type": "color",
      "text": {
        "primary": {
          "base": {
            "$value": "{color.text.primary}"
          },
          "hover": {
            "$value": "{color.text.primary-hover}"
          },
          "active": {
            "$value": "{color.text.primary-active}"
          }
        },
        "inverted": {
          "base": {
            "$value": "{color.text.white}"
          },
          "hover": {
            "$value": "{color.text.inverted-primary-hover}"
          },
          "active": {
            "$value": "{color.text.inverted-primary-active}"
          }
        }
      }
    },
    "shadow": {
      "outline": {
        "$type": "shadow",
        "base": {
          "$value": "{shadow.outline.base}"
        },
        "inverted": {
          "$value": "{shadow.outline.inverted}"
        }
      }
    }
  }
}
