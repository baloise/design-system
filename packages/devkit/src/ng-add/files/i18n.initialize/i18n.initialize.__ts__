import {
  DsConfigState,
  DsLanguage,
  onDsConfigChange,
} from '@baloise/ds-core';
import { DsConfigService } from '@baloise/ds-angular';
import { TranslocoService } from '@ngneat/transloco';

export function initializeI18n(
  transloco: TranslocoService,
  dsConfig: DsConfigService
) {
  return (): Promise<void> => {
    const activeLanguage = transloco.getActiveLang() as DsLanguage;
    const allowedLanguages = transloco.getAvailableLangs() as DsLanguage[];

    dsConfig.setLanguage(activeLanguage);
    dsConfig.setAllowedLanguages(allowedLanguages);

    onDsConfigChange((config: DsConfigState) => {
      if (transloco.getActiveLang() !== config.language) {
        transloco.setActiveLang(config.language);
      }
    });

    transloco.langChanges$.subscribe((value) => {
      dsConfig.setLanguage(value as DsLanguage);
    });

    return Promise.resolve();
  };
}
