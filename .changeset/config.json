{
  "$schema": "https://unpkg.com/@changesets/config@2.3.0/schema.json",
  "changelog": ["./my-changelog-config.js", { "repo": "baloise/design-system" }],
  "commit": false,
  "fixed": [["@baloise/ds-*"]],
