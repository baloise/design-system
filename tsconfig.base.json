{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": ".",
    "sourceMap": false,
    "declaration": false,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "importHelpers": true,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "moduleResolution": "node",
    "target": "es2017",
    "module": "esnext",
    "lib": [
      "es2020",
      "dom"
    ],
    "paths": {
      "@utils": [
        "packages/core/src/utils/index.ts"
      ],
      "@global": [
        "packages/core/src/global/index.ts"
      ],
      "@baloise/ds-core": [
        "packages/core/src/index.ts"
      ],
      "@baloise/ds-tokens": [
        "packages/tokens/dist/tokens.js"
      ],
      "@baloise/ds-playwright": [
        "packages/playwright/src/index.ts"
      ],
      "@baloise/output-target-angular": [
        "libs/output-target-angular/src/index.ts"
      ],
      "@baloise/output-target-web": [
        "libs/output-target-web/src/index.ts"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "tmp"
  ]
}
