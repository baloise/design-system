{
  "name": "design-system",
  "$schema": "node_modules/nx/schemas/project-schema.json",
  "targets": {
    "changeset": {
      "executor": "@baloise/ds-nx:create-changeset",
      "options": {
        "workspaceRoot": "{workspaceRoot}",
        "projectRoot": "{projectRoot}"
      }
    },
    "pre-publish": {
      "executor": "@baloise/ds-nx:pre-publish",
      "options": {
        "workspaceRoot": "{workspaceRoot}",
        "projectRoot": "{projectRoot}"
      }
    }
  }
}
