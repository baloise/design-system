{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[mdx]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": false
  },
  "files.eol": "\n",
  "vsicons.associations.files": [
    {
      "icon": "playwright",
      "extensions": [".play.ts"],
      "format": "svg"
    },
    {
      "icon": "registry",
      "extensions": [".po.ts"],
      "format": "svg"
    }
  ],
  "vsicons.associations.folders": [
    {
      "icon": "app",
      "extensions": ["global"]
    },
    {
      "icon": "component",
      "extensions": ["core"]
    },
    {
      "icon": "cli",
      "extensions": ["devkit"]
    },
    {
      "icon": "db",
      "extensions": ["tokens"]
    },
    {
      "icon": "test",
      "extensions": ["playwright", "spec", "test"]
    }
  ],
  "vitest.disableWorkspaceWarning": true
}
