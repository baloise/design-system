{
  "name": "design-system",
  "version": "0.0.0",
  "homepage": "https://design.baloise.dev",
  "license": "Apache-2.0",
  "scripts": {
    "start": "IS_DS_DEVELOPMENT=true npx nx run core:start",
    "start:force": "npx nx reset && npm run start",
    "docs": "npx nx run docs:start",
    "docs:force": "npx nx reset && npm run docs",
    "e2e": "npx nx run e2e:start",
    "play": "npx nx run core:e2e-ui",
    "build": "npx nx run-many -t build",
    "build:force": "npx nx reset && npm run build",
    "tokens": "npx nx run tokens:build",
    "tokens:force": "npx nx reset && npm run tokens",
    "styles": "npx nx run styles:build",
    "styles:force": "npx nx reset && npm run styles",
    "styles:dev": "npx nx run styles:build -- --dev",
    "styles:dev:force": "npx nx reset && npm run styles:dev",
    "lint": "npx nx run-many -t lint",
    "test": "npx nx run-many -t test -- --watch=false",
    "format": "npx nx format:write --all --end-of-line lf",
    "format:check": "npx nx format:check --all --end-of-line lf",
    "spell": "cspell --no-progress",
    "registry": "bash registry",
    "changeset": "npx nx run changeset",
    "optimize": "npx nx run-many -t optimize",
    "angular": "npx nx run angular-create",
    "angular:start": "npx nx run angular-start",
    "react": "npx nx run react-create",
    "react:start": "npx nx run react-start",
    "kill:ports": "kill -9 $(lsof -t -i:4000) || true && kill -9 $(lsof -t -i:4001) || true && kill -9 $(lsof -t -i:4002) || true && kill -9 $(lsof -t -i:4003) || true && kill -9 $(lsof -t -i:4004) || true"
  },
  "nx": {
    "includedScripts": []
  },
  "private": true,
  "workspaces": [
    "packages/*",
    "libs/*",
    "docs",
    "e2e"
  ],
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "@changesets/get-github-info": "0.8.0",
    "@changesets/types": "6.1.0",
    "@eslint/js": "10.0.1",
    "@nx/angular": "22.7.1",
    "@nx/devkit": "22.7.1",
    "@nx/eslint": "22.7.1",
    "@nx/eslint-plugin": "22.7.1",
    "@nx/js": "22.7.1",
    "@nx/playwright": "22.7.1",
    "@nx/plugin": "22.7.1",
    "@nx/react": "22.7.1",
    "@nx/rollup": "22.7.1",
    "@nx/vite": "22.7.1",
    "@nx/web": "22.7.1",
    "@playwright/test": "1.59.1",
    "@stencil/core": "4.43.4",
    "@stencil/react-output-target": "1.5.2",
    "@stencil/sass": "3.2.3",
    "@storybook/addon-docs": "10.3.6",
    "@storybook/addon-links": "10.3.6",
    "@storybook/html-vite": "10.3.6",
    "@swc-node/register": "1.11.1",
    "@swc/cli": "0.8.1",
    "@swc/core": "1.15.33",
    "@swc/helpers": "0.5.21",
    "@types/fs-extra": "11.0.4",
    "@types/node": "22.19.17",
    "@typescript-eslint/eslint-plugin": "8.59.2",
    "@typescript-eslint/parser": "8.59.2",
    "@typescript-eslint/utils": "8.59.2",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/ui": "4.1.5",
    "autoprefixer": "10.5.0",
    "baseline-browser-mapping": "2.10.27",
    "compression": "1.8.1",
    "cspell": "9.8.0",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-playwright": "2.10.2",
    "express": "5.2.1",
    "fast-deep-equal": "3.1.3",
    "fs-extra": "11.3.5",
    "glob": "10.5.0",
    "jiti": "2.7.0",
    "jsdom": "29.1.1",
    "jsonc-eslint-parser": "3.1.0",
    "kill-port": "2.0.1",
    "lightningcss": "1.32.0",
    "lodash": "4.18.1",
    "nx": "22.7.1",
    "postcss": "8.5.14",
    "prettier": "3.8.3",
    "prompts": "2.4.2",
    "rimraf": "6.1.3",
    "sass": "1.99.0",
