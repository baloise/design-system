{
  "name": "design-system",
  "version": "0.0.0",
  "homepage": "https://design.baloise.dev",
  "license": "Apache-2.0",
  "packageManager": "npm@11.1.0",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "_dev": "====================================================== Development ================================================",
    "start": "npm --prefix packages/core run start",
    "start:force": "turbo run build --force && npm run start",
    "docs": "turbo run build --filter=@baloise/ds-core && node scripts/build-docs.mjs --serve && storybook dev -p 6006 --config-dir docs/.storybook",
    "docs:preview": "turbo run build --filter=@baloise/ds-core && node scripts/build-docs.mjs && http-server docs/dist -p 6006",
    "_playwright": "=============================================== Playwright =================================================",
    "play": "npm --prefix packages/core run play",
    "play:file": "npm --prefix packages/core run play:file",
    "play:a11y": "npm --prefix packages/core run play:a11y",
    "play:components": "npm --prefix packages/core run play:components",
    "play:visual": "npm --prefix packages/core run play:visual",
    "play:update": "npm --prefix packages/core run play:update",
    "play:ci": "npm --prefix packages/core run play:ci",
    "_build": "==================================================== Build =====================================================",
    "build": "turbo run build --filter=@baloise/ds-core && node scripts/build-docs.mjs",
    "build:force": "turbo run build --force",
    "tokens": "turbo run build --filter=@baloise/ds-tokens --force",
    "css": "turbo run build --filter=@baloise/ds-css --force",
    "assets": "turbo run build --filter=@baloise/ds-assets --force",
    "core": "turbo run build --filter=@baloise/ds-core --force",
    "_test": "===================================================== Test & Lint ===============================================",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "_utilities": "================================================ Utilities =================================================",
    "format": "npx prettier --write --end-of-line lf .",
    "format:check": "npx prettier --check --end-of-line lf .",
    "spell": "cspell --no-progress",
    "registry": "bash registry",
    "changeset": "node scripts/create-changeset.mjs"
  },
  "private": true,
  "workspaces": [
    "packages/*",
    "libs/*",
    "docs"
  ],
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "@changesets/get-github-info": "0.8.0",
    "@changesets/types": "6.1.0",
    "@cyclonedx/cyclonedx-npm": "4.2.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.59.1",
    "@stencil/core": "4.43.4",
    "@stencil/react-output-target": "1.5.2",
    "@stencil/sass": "3.2.3",
    "@storybook/addon-docs": "10.4.0",
    "@storybook/addon-links": "10.4.0",
    "@storybook/html-vite": "10.4.0",
    "@swc/cli": "0.8.1",
    "@types/fs-extra": "11.0.4",
    "@types/node": "24.12.4",
    "@typescript-eslint/eslint-plugin": "8.59.4",
    "@typescript-eslint/parser": "8.59.4",
    "@typescript-eslint/utils": "8.59.4",
    "@vitest/ui": "4.1.6",
    "archiver": "^8.0.0",
    "compression": "1.8.1",
    "cross-env": "7.0.3",
    "cspell": "10.0.0",
    "eslint": "10.4.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-playwright": "2.10.3",
    "express": "5.2.1",
    "fast-deep-equal": "3.1.3",
    "fs-extra": "11.3.5",
    "glob": "13.0.6",
    "jsdom": "29.1.1",
    "jsonc-eslint-parser": "3.1.0",
    "kill-port": "2.0.1",
    "lodash": "4.18.1",
    "prettier": "3.8.3",
    "prompts": "2.4.2",
    "rimraf": "6.1.3",
    "sass": "1.99.0",
    "serve-index": "1.9.2",
    "storybook": "10.4.0",
    "style-dictionary": "5.4.1",
    "svgo": "4.0.1",
    "tsx": "^4.22.2",
    "turbo": "^2.9.14",
    "typescript": "5.6.3",
    "typescript-eslint": "8.59.4",
    "vite": "8.0.13",
    "vitest": "4.1.6"
  },
  "optionalDependencies": {
    "@oxc-parser/binding-linux-arm64-gnu": "0.132.0",
    "@oxc-parser/binding-linux-x64-gnu": "0.132.0"
  },
  "overrides": {
    "chokidar": "4.0.3",
    "vite": "8.0.13",
    "@babel/runtime": "7.27.3",
    "axios": "1.16.0",
    "yaml": "2.8.4"
  }
}
