    "typescript-eslint": "8.59.2",
    "vite": "8.0.11",
    "vitest": "4.1.5"
  },
  "overrides": {
    "chokidar": "4.0.3",
    "vite": "8.0.11",
    "@babel/runtime": "7.27.3",
    "axios": "1.16.0",
    "yaml": "2.8.4"
  }
}
