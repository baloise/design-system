{
  "name": "design-system",
  "version": "0.0.0",
  "homepage": "https://design.baloise.dev",
  "license": "Apache-2.0",
  "packageManager": "npm@10.0.0",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "start": "IS_DS_DEVELOPMENT=true && cd packages/core && stencil build --dev --serve --watch --port=4000",
    "start:force": "turbo run build --force && npm run start",
    "docs": "node scripts/build-docs.mjs --serve && storybook dev -p 6006 --config-dir docs/.storybook",
    "e2e": "cd packages/core && NODE_OPTIONS='--disable-warning=DEP0205' npx playwright test",
    "play": "cd packages/core && NODE_OPTIONS='--disable-warning=DEP0205' npx playwright test --ui",
    "build": "turbo run build",
    "build:force": "turbo run build --force",
    "tokens": "turbo run build --filter=@baloise/ds-tokens --force",
    "css": "turbo run build --filter=@baloise/ds-css --force",
    "assets": "turbo run build --filter=@baloise/ds-assets --force",
    "core": "turbo run build --filter=@baloise/ds-core --force",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "npx prettier --write --end-of-line lf .",
    "format:check": "npx prettier --check --end-of-line lf .",
    "spell": "cspell --no-progress",
    "registry": "bash registry",
    "changeset": "node scripts/create-changeset.mjs",
    "kill:ports": "kill -9 $(lsof -t -i:4000) || true && kill -9 $(lsof -t -i:4001) || true && kill -9 $(lsof -t -i:4002) || true && kill -9 $(lsof -t -i:4003) || true && kill -9 $(lsof -t -i:4004) || true"
  },
  "nx": {
    "includedScripts": []
  },
  "private": true,
  "workspaces": [
    "packages/*",
    "libs/*",
    "docs"
  ],
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "@changesets/get-github-info": "0.8.0",
    "@changesets/types": "6.1.0",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.59.1",
    "@stencil/core": "4.43.4",
    "@stencil/react-output-target": "1.5.2",
    "@stencil/sass": "3.2.3",
    "@storybook/addon-docs": "10.3.6",
    "@storybook/addon-links": "10.3.6",
    "@storybook/html-vite": "10.3.6",
    "@swc-node/register": "1.11.1",
    "@swc/cli": "0.8.1",
    "@swc/core": "1.15.33",
    "@swc/helpers": "0.5.21",
    "@types/fs-extra": "11.0.4",
    "@types/node": "22.19.17",
    "@typescript-eslint/eslint-plugin": "8.59.2",
    "@typescript-eslint/parser": "8.59.2",
    "@typescript-eslint/utils": "8.59.2",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/ui": "4.1.5",
    "archiver": "^7.0.0",
    "autoprefixer": "10.5.0",
    "baseline-browser-mapping": "2.10.27",
    "compression": "1.8.1",
    "cspell": "9.8.0",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-playwright": "2.10.2",
    "express": "5.2.1",
    "fast-deep-equal": "3.1.3",
    "fs-extra": "11.3.5",
    "glob": "10.5.0",
    "jiti": "2.7.0",
    "jsdom": "29.1.1",
    "jsonc-eslint-parser": "3.1.0",
    "kill-port": "2.0.1",
    "lightningcss": "1.32.0",
    "lodash": "4.18.1",
    "postcss": "8.5.14",
    "prettier": "3.8.3",
    "prompts": "2.4.2",
    "rimraf": "6.1.3",
    "sass": "1.99.0",
    "serve-index": "1.9.2",
    "storybook": "10.3.6",
    "style-dictionary": "5.4.0",
    "svgo": "3.3.3",
    "tsx": "^4.19.1",
    "turbo": "^2.9.10",
    "typescript": "5.6.3",
    "typescript-eslint": "8.59.2",
    "vite": "8.0.11",
    "vitest": "4.1.5"
  },
  "overrides": {
    "chokidar": "4.0.3",
    "vite": "8.0.11",
    "@babel/runtime": "7.27.3",
    "axios": "1.16.0",
    "yaml": "2.8.4"
  }
}
